<!DOCTYPE html>
<html>
<head>
  <title>SmartEduConnect</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <div class="center-page">
    <div class="center-card">
      <h1 class="hero-title">SmartEduConnect Portal</h1>
      <p class="hero-subtitle">
        A unified digital campus platform for academic management, attendance, marks, course tracking, and faculty coordination.
      </p>

      <div class="role-grid">
        <div class="role-card">
          <h3>Student</h3>
          <p>Access attendance, marks, profile, and course details through a dedicated student dashboard.</p>
          <a class="btn" href="login.html?role=student">Continue as Student</a>
        </div>

        <div class="role-card">
          <h3>Faculty</h3>
          <p>Manage attendance, upload marks, and view assigned courses through the faculty portal.</p>
          <a class="btn" href="login.html?role=faculty">Continue as Faculty</a>
        </div>

        <div class="role-card">
          <h3>Admin</h3>
          <p>Manage students, faculty, courses, and institutional workflows through the admin control panel.</p>
          <a class="btn" href="login.html?role=admin">Continue as Admin</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>